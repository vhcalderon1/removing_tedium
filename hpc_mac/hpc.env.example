# Copy this file to ./hpc.env in your project root and edit the values.
# The helper scripts source ./hpc.env from the project root.

# Short SSH alias from ~/.ssh/config or a full login host name.
HPC_HOST="YOUR_CLUSTER_ALIAS_OR_LOGIN_HOST"

# Your cluster user name. Usually this is the same as your local user name,
# but set it explicitly if the cluster account differs.
HPC_USER="YOUR_NETID_OR_USERNAME"

# Remote directory that will contain project folders.
# Examples:
#   /scratch/gpfs/YOUR_GROUP/YOUR_NETID/projects
#   /scratch/network/YOUR_NETID/projects
#   /home/YOUR_NETID/projects
HPC_REMOTE_ROOT="/scratch/YOUR_GROUP/YOUR_NETID/projects"

# Optional. Leave empty to use the local project directory name.
HPC_PROJECT_NAME=""

# Optional. Leave empty to use ${HPC_REMOTE_ROOT}/${HPC_PROJECT_NAME}.
HPC_REMOTE_DIR=""

# Slurm script to submit from the remote project directory.
HPC_SLURM_SCRIPT="job.slurm"

# Local rsync exclude file. The default works after copying hpc_mac into a project.
HPC_EXCLUDES="hpc_mac/rsync_excludes.txt"

# Set to 1 only if you want local deletions mirrored to the cluster.
HPC_RSYNC_DELETE=0

# Local folder where hpc-fetch-results writes downloaded outputs.
HPC_LOCAL_RESULTS_DIR="hpc_results"
