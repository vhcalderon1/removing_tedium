#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/hpc-common.sh"

[[ -f "${HPC_EXCLUDES}" ]] || hpc_die "exclude file not found: ${HPC_EXCLUDES}"

RSYNC_DELETE_FLAG=()
if [[ "${HPC_RSYNC_DELETE}" == "1" ]]; then
  RSYNC_DELETE_FLAG=(--delete)
fi

echo "Creating remote directory: ${HPC_SSH_TARGET}:${HPC_REMOTE_DIR}"
ssh "${HPC_SSH_TARGET}" "mkdir -p $(hpc_quote "${HPC_REMOTE_DIR}")"

echo "Syncing ${HPC_PROJECT_DIR}/ to ${HPC_SSH_TARGET}:${HPC_REMOTE_DIR}/"
rsync -azP \
  "${RSYNC_DELETE_FLAG[@]}" \
  --exclude-from="${HPC_EXCLUDES}" \
  "${HPC_PROJECT_DIR}/" \
  "${HPC_SSH_TARGET}:${HPC_REMOTE_DIR}/"

echo "Sync complete."
